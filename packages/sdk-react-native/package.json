{
  "name": "@onramp-sdk/react-native",
  "version": "0.7.2",
  "description": "OnRamp onboarding funnel analytics for React Native - track steps, see where users drop off. Expo-compatible.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getonramp/onramp-sdk.git",
    "directory": "packages/sdk-react-native"
  },
  "homepage": "https://getonramp.dev/docs/sdks/react-native",
  "bugs": { "url": "https://github.com/getonramp/onramp-sdk/issues" },
  "keywords": [
    "react-native",
    "expo",
    "analytics",
    "onboarding",
    "funnel"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@onramp-sdk/core": "workspace:*",
    "@onramp-sdk/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@react-navigation/native": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@react-navigation/native": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-navigation/native": "^6.1.0",
    "react": "^18.3.0",
    "react-native": "^0.76.0"
  }
}
